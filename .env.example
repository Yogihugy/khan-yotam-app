# === Shared / Frontend (Vercel) ===
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_API_URL=http://localhost:3001
VITE_KHAN_LAT=32.6905
VITE_KHAN_LNG=34.9433
VITE_MAP_BOUNDS_SW=29.5,34.2
VITE_MAP_BOUNDS_NE=33.09,35.6
VITE_APP_NAME=Chan Yotam

# === Backend (Render) ===
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public app URL used in invite WhatsApp links
APP_URL=http://localhost:5173

# Session duration defaults (days). admin = no expiry (null)
GUEST_SESSION_DAYS=15
STAFF_SESSION_DAYS=365

# WhatsApp via WATI (set WATI_MOCK=true for local stub)
WATI_API_ENDPOINT=https://live-server-XXXX.wati.io
WATI_API_KEY=
WATI_MOCK=true
# Optional: approved template name for outbound invites (required when not mocking)
WATI_INVITE_TEMPLATE_NAME=invite_sea_trail
WATI_INVITE_TEMPLATE_LANGUAGE=he

# Distress SMS via Twilio (invites still use WATI above)
# SMS_MOCK defaults to true until a real From number + credentials are set
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555550100
SMS_MOCK=true

# Pepper for hashing SMS OTP codes (self-registration). Never commit a real secret.
OTP_PEPPER=change-me-to-a-long-random-string

# Seed script defaults (server/scripts/seed.js)
SEED_ADMIN_EMAIL=admin@khanyotam.local
SEED_ADMIN_PASSWORD=change-me-on-first-login
SEED_ADMIN_NAME=Admin
SEED_ADMIN_PHONE=+972500000000
SEED_EMERGENCY_PHONE=+972500000001
SEED_DUTY_OFFICER_NAME=Duty Officer
SEED_DUTY_OFFICER_PHONE=+972500000001
